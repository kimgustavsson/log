---
// Dynamic route for dev log posts. getStaticPaths() turns every Markdown file
// in the devlog collection into its own page at /devlog/<slug>/.
import { render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { buildPostPaths, estimateReadingTime } from '../../lib/posts';

export async function getStaticPaths() {
  return buildPostPaths('devlog', '/devlog');
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
const readingTime = estimateReadingTime(entry.body);
---

<PostLayout
  title={entry.data.title}
  description={entry.data.description}
  date={entry.data.date}
  tags={entry.data.tags}
  slug={`devlog/${entry.id}`}
  section="Dev log"
  basePath="/devlog"
  readingTime={readingTime}
  prev={prev}
  next={next}
>
  <Content />
</PostLayout>
