---
// Dynamic route for writing posts. Mirrors the dev log route — same pattern,
// different collection — so both sections stay consistent.
import { render } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import { buildPostPaths, estimateReadingTime } from '../../lib/posts';

export async function getStaticPaths() {
  return buildPostPaths('writing', '/writing');
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);
const readingTime = estimateReadingTime(entry.body);
---

<PostLayout
  title={entry.data.title}
  description={entry.data.description}
  date={entry.data.date}
  tags={entry.data.tags}
  slug={`writing/${entry.id}`}
  section="Writing"
  basePath="/writing"
  readingTime={readingTime}
  prev={prev}
  next={next}
>
  <Content />
</PostLayout>
