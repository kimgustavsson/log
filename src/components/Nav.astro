---
// Top navigation. Fixed, turns opaque on scroll, collapses to a two-bar
// hamburger toggle below desktop width. Links are passed in so the same bar
// works on any page.
const links = [
  { label: 'Dev Log', href: '/devlog' },
  { label: 'Writing', href: '/writing' },
  { label: 'About', href: '/about' },
];
const social = [
  { label: 'LinkedIn', href: 'https://www.linkedin.com/', external: true },
];
---

<nav id="nav">
  <div class="nav-inner">
    <a class="logo" href="/">Kim Dasha Gustavsson</a>
    <button class="menu-toggle" id="mtoggle" aria-label="Toggle menu">
      <span class="mt-bars" aria-hidden="true"><span></span><span></span></span>
      <span class="mt-label">Close</span>
    </button>
    <div class="nav-links" id="navlinks">
      <div class="nl-group nl-main">
        <a href="/" class="home-link">Home</a>
        {links.map((l) => <a href={l.href}>{l.label}</a>)}
      </div>
      <div class="nl-group nl-social">
        {social.map((l) => <a class="ext" href={l.href} target="_blank" rel="noopener">{l.label}</a>)}
      </div>
    </div>
  </div>
</nav>

<style>
  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; padding: 22px clamp(20px, 5vw, 56px); transition: background .4s ease; border-bottom: 1px solid var(--line); will-change: background-color; }
  nav.scrolled { background: color-mix(in srgb, var(--seafoam) 90%, transparent); backdrop-filter: blur(12px); }
  /* backdrop-filter makes `nav` a containing block for its position:fixed
     descendants (the mobile menu and its Close button), so they'd end up
     positioned relative to nav's own small box instead of the viewport —
     and drift as the page scrolls. Drop it while the menu is open. */
  nav.scrolled.menu-open { backdrop-filter: none; }
  .nav-inner { max-width: var(--maxw-content); margin: 0 auto; display: flex; align-items: center; justify-content: space-between; }
  .logo { font-family: var(--serif); font-weight: 500; font-size: 20px; letter-spacing: -.01em; display: flex; align-items: center; gap: 9px; color: var(--luxe); }
  .nav-links { display: flex; gap: clamp(18px, 2.4vw, 34px); font-size: 14px; letter-spacing: .01em; }
  .nl-group { display: contents; }
  .nav-links a { padding: 3px 0; color: var(--pine); transition: color .25s; }
  .nav-links a:hover { color: var(--accent); }
  .menu-toggle { display: none; align-items: center; background: none; border: none; color: var(--pine); cursor: pointer; }
  .mt-bars { display: flex; flex-direction: column; gap: 5px; }
  .mt-bars span { display: block; width: 20px; height: 2px; background: currentColor; }
  .mt-label { display: none; font-size: 14px; font-family: var(--sans); font-weight: 600; }
  .menu-toggle.open .mt-bars { display: none; }
  .menu-toggle.open .mt-label { display: inline; }
  .home-link { display: none; }
  @media (max-width: 760px) {
    nav { padding: 18px 20px; }
    .menu-toggle { position: relative; z-index: 2; display: flex; }
    .menu-toggle.open { position: fixed; top: auto; bottom: 28px; right: 24px; color: var(--white); }
    .nav-links {
      position: fixed; top: 0; left: 0; right: 0; height: 100vh; z-index: 1;
      background: var(--luxe);
      flex-direction: column;
      align-items: stretch;
      justify-content: space-between;
      padding: clamp(90px, 16vh, 130px) 32px;
      font-size: 19px;
      overflow: hidden;
      transform: translateY(-100%);
      transition: transform .45s ease;
    }
    .nav-links.open { transform: translateY(0); }
    .nl-group { display: flex; flex-direction: column; gap: 20px; }
    .nav-links a { font-family: var(--serif); color: var(--white); opacity: .85; padding: 0; }
    .nav-links a:hover { color: var(--accent); opacity: 1; }
    .home-link { display: block; font-size: 30px; font-weight: 700; color: var(--white); opacity: 1; }
  }
</style>

<script>
  // Toggle the opaque background once the user scrolls past the hero top.
  // Reads scrollY in a rAF tick (not on every raw scroll event) and only
  // touches the DOM when the threshold is actually crossed, so the
  // backdrop-filter blur isn't recomputed on every scroll tick.
  const nav = document.getElementById('nav');
  let isScrolled = false;
  let ticking = false;
  addEventListener(
    'scroll',
    () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const shouldScroll = scrollY > 40;
        if (shouldScroll !== isScrolled) {
          isScrolled = shouldScroll;
          nav?.classList.toggle('scrolled', isScrolled);
        }
        ticking = false;
      });
    },
    { passive: true }
  );

  // Mobile menu open/close. Locks page scroll while open so the menu stays a
  // single, static screen instead of scrolling (and dragging the fixed
  // "Close" label up and down) along with the page underneath.
  const toggle = document.getElementById('mtoggle');
  const linksEl = document.getElementById('navlinks');
  const setOpen = (open: boolean) => {
    linksEl?.classList.toggle('open', open);
    toggle?.classList.toggle('open', open);
    nav?.classList.toggle('menu-open', open);
    document.body.style.overflow = open ? 'hidden' : '';
  };
  toggle?.addEventListener('click', () => setOpen(!linksEl?.classList.contains('open')));
  linksEl?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
</script>