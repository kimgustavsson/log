---
// Top navigation. Fixed, turns opaque on scroll, collapses to a toggle on mobile.
// Links are passed in so the same bar works on any page.
const links = [
  { label: 'Dev Log', href: '/#devlog' },
  { label: 'Writing', href: '/#writing' },
    { label: 'About', href: '/about' },
  { label: 'Linkedin', href: 'https://www.linkedin.com/', external: true },
];
---

<nav id="nav">
  <div class="nav-inner">
    <a class="logo" href="/"> Kim Dasha Gustavsson</a>
    <button class="menu-toggle" id="mtoggle" aria-label="Toggle menu">Menu</button>
    <div class="nav-links" id="navlinks">
      {links.map((l) =>
        l.external ? (
          <a class="ext" href={l.href} target="_blank" rel="noopener">{l.label}</a>
        ) : (
          <a href={l.href}>{l.label}</a>
        )
      )}
    </div>
  </div>
</nav>

<style>
  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 50; padding: 22px clamp(20px, 5vw, 56px); transition: background .4s ease, border-color .4s ease; border-bottom: 1px solid transparent; }
  nav.scrolled { 
    background: rgba(255, 255, 255, 0.6);
    -webkit-backdrop-filter: blur(12px); 
    backdrop-filter: blur(12px); 
    border-bottom: 1px solid var(--line); 
  }
  .nav-inner { max-width: var(--maxw-content); margin: 0 auto; display: flex; align-items: center; justify-content: space-between; }
  .logo { font-family: var(--serif); font-weight: 500; font-size: 20px; letter-spacing: -.01em; display: flex; align-items: center; gap: 9px; color: var(--luxe); }
  .logo .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--luxe); display: inline-block; }
  .nav-links { display: flex; gap: clamp(18px, 2.4vw, 34px); font-size: 14px; letter-spacing: .01em; }
  .nav-links a { position: relative; padding: 3px 0; color: var(--luxe); opacity: .9; transition: opacity .25s; }
  .nav-links a::after { content: ""; position: absolute; left: 0; bottom: -2px; height: 1px; width: 0; background: currentColor; transition: width .3s ease; }
  .nav-links a:hover { opacity: 1; }
  .nav-links a:hover::after { width: 100%; }
  .menu-toggle { display: none; background: none; border: none; color: var(--luxe); font-size: 14px; font-family: var(--sans); cursor: pointer; }
  @media (max-width: 760px) {
    .menu-toggle { display: block; }
    .nav-links { position: fixed; inset: 0; background: var(--white); flex-direction: column; justify-content: center; align-items: center; gap: 30px; font-size: 26px; transform: translateY(-100%); transition: transform .45s ease; }
    .nav-links.open { transform: translateY(0); }
  }
</style>

<script>
  // Toggle the opaque background once the user scrolls past the hero top.
  const nav = document.getElementById('nav');
  addEventListener('scroll', () => nav?.classList.toggle('scrolled', scrollY > 40), { passive: true });

  // Mobile menu open/close.
  const toggle = document.getElementById('mtoggle');
  const linksEl = document.getElementById('navlinks');
  toggle?.addEventListener('click', () => {
    const open = linksEl?.classList.toggle('open');
    if (toggle) toggle.textContent = open ? 'Close' : 'Menu';
  });
  linksEl?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      linksEl.classList.remove('open');
      if (toggle) toggle.textContent = 'Menu';
    })
  );
</script>
