---
// Hero: left-aligned editorial layout. Small muted role line, a big sans-serif
// statement headline, a short supporting line, then a 3-column meta block
// (name / contact / channels) at the bottom. Lines up with the same max-width
// column as the nav and footer. The page rail is handled elsewhere and
// untouched here.
//
// All copy is prop-driven so you can edit without touching markup.
import MailButton from './MailButton.astro';

interface Props {
  roles?: string[];     // muted keyword line, first one is emphasized
  headline?: string;    // big statement (this is the focal point)
  sub?: string;         // small supporting line under the headline
  name?: string;        // meta column 1 heading
  caption?: string;     // meta column 1 body (use \n for line breaks)
  email?: string;       // full address; split internally so it's not in the HTML
  linkedin?: string;
  github?: string;
}
const {
  roles = ['AI Engineer', 'Software Developer'],
  headline = 'This space is an archive of my experiments and everyday problem-solving.',
  sub = 'It is where I test ideas, hit technical roadblocks, and relentlessly figure out how to make them work.',
  name = 'NOW',
  caption = 'MSc in Artificial Intelligence\nBased in Brisbane, Australia',
  email = 'you@example.com',
  linkedin = '#',
  github = '#',
} = Astro.props;

const [mailUser, mailDomain] = email.split('@');
---

<header class="hero" id="top">
  <div class="hero-inner">
    <div class="h-roles">
      <span class="roles-text">
        {roles.map((r, i) => (
          <>
            {i > 0 && <span class="h-sep">·</span>}
            <span class={i === 0 ? 'on' : ''}>{r}</span>
          </>
        ))}
      </span>
      <span class="r-line" aria-hidden="true"></span>
    </div>
    <div class="h-head-wrap">
      <h1 class="h-head">{headline}</h1>
      <h1 class="h-head h-head-fill" aria-hidden="true">{headline}</h1>
    </div>
    <p class="h-sub fade-up" data-delay="200">{sub}</p>
  </div>

  <div class="h-meta fade-up" data-delay="300">
    <div class="blk blk-name">
      <h4>{name}</h4>
      <div class="v it" set:html={caption.replace(/\n/g, '<br>')} />
    </div>
    <div class="blk">
      <h4>Contact</h4>
      <div class="v"><MailButton user={mailUser} domain={mailDomain} label="Email" /></div>
    </div>
    <div class="blk">
      <h4>Channels</h4>
      <div class="v"><a href={linkedin} target="_blank" rel="noopener">LinkedIn</a><br><a href={github} target="_blank" rel="noopener">GitHub</a></div>
    </div>
  </div>
</header>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    background: var(--seafoam);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* identity + statement, left-aligned in the shared column */
  .hero-inner {
    flex: 1;
    width: 100%;
    max-width: var(--maxw-content);
    margin: 0 auto;
    padding: 0 clamp(24px, 9vw, 140px);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .h-roles {
    position: relative;
    font-size: 13px;
    color: var(--muted);
    margin-bottom: 22px;
    text-transform: uppercase;
    letter-spacing: 1.98px;
  }
  .h-roles .on { color: var(--ink); }
  .h-roles .h-sep { margin: 0 12px; opacity: .5; }

  /* sweeping line drawn ahead of the role letters on load */
  .h-roles .r-line {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 2px;
    background: var(--ink);
    opacity: 0;
    transform: scaleY(0) translateX(0);
    transform-origin: 0 50%;
  }
  .h-roles .r-line.in-grow {
    opacity: 1;
    transform: scaleY(1) translateX(0);
    transition: transform .45s cubic-bezier(.16, 1, .3, 1), opacity .3s ease;
  }
  .h-roles .r-line.in-sweep {
    transform: scaleY(1) translateX(var(--sweep-x, 0px));
    /* duration is set inline (--sweep-duration) to match how long the
       letters take to cascade in, so the bar travels at their pace
       instead of a fixed speed that outruns short text or lags long text */
    transition: transform var(--sweep-duration, .7s) linear;
  }
  .h-roles .r-line.out {
    opacity: 0;
    transition: opacity .4s ease;
  }

  /* :global because these spans are inserted client-side by reveal.ts and
     don't carry Astro's scoped data-astro-cid attribute */
  :global(.h-roles .letter) {
    display: inline-block;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity .5s ease, transform .5s cubic-bezier(.16, 1, .3, 1);
  }
  :global(.h-roles .letter.in) {
    opacity: 1;
    transform: none;
  }

  .h-head-wrap { position: relative; }

  .h-head {
    font-family: var(--serif);
    font-weight: 600;
    font-size: clamp(30px, 5vw, 60px);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--luxe);
    max-width: 17ch;
    margin-bottom: 20px;
    overflow-wrap: break-word;
  }

  /* cursor-following circle that recolors the headline as it passes over —
     an absolutely-positioned duplicate of the headline, clipped to a circle
     that JS moves to the cursor, sitting on top of the normal-colored text */
  .h-head-fill {
    position: absolute;
    inset: 0;
    margin: 0;
    color: var(--accent);
    pointer-events: none;
    clip-path: circle(0px at 50% 50%);
    transition: clip-path .15s ease-out;
  }

  .h-sub {
    font-size: clamp(15px, 1.4vw, 16px);
    line-height: 1.6;
    color: var(--ink);
    max-width: 42ch;
  }

  /* bottom 3-column meta, generous gap before the page end */
  .h-meta {
    position: relative;
    width: 100%;
    max-width: var(--maxw-content);
    margin: 0 auto clamp(80px, 13vh, 150px);
    padding: 30px clamp(24px, 9vw, 140px) 30px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  /* matching centered rules above and below the meta content, both sized to
     the width of dividers used elsewhere on the site (var(--maxw-read))
     instead of a full-width border that stretches to the wider hero column */
  .h-meta::before,
  .h-meta::after {
    content: "";
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: var(--maxw-read);
    max-width: 100%;
    height: 1px;
    background: var(--line);
  }
  .h-meta::before { top: 0; }
  .h-meta::after { bottom: 0; }
  .h-meta .blk h4 {
    font-size: 13px;
    font-weight: 400;
    color: var(--muted);
    margin-bottom: 30px;
    text-transform: uppercase;
    letter-spacing: 1.98px;
  }
  .h-meta .blk .v {
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink);
  }
  .h-meta .blk .v.it { color: var(--ink); }
  .h-meta a { color: var(--ink); transition: color .2s; }
  .h-meta a:hover { color: var(--accent); }

  @media (max-width: 680px) {
    .hero-inner {
      padding: 0 45px;
      justify-content: flex-start;
      padding-top: clamp(72px, 10vh, 100px);
    }
    .h-roles {
      font-size: 10px;
      letter-spacing: 0.5px;
      margin-bottom: 14px;
    }
    .h-head {
      display: block;
      font-size: clamp(28px, 7vw, 34px);
      line-height: 1.12;
      margin-bottom: 35px;
      max-width: 100%;
    }
    .h-sub {
      display: block;
      font-size: 14px;
      margin-bottom: 24px;
      line-height: 1.65;
      max-width: 100%;
    }
    .h-meta {
      grid-template-columns: 1fr;
      gap: 24px;
      padding: 24px 45px;
      margin-bottom: 72px;
    }
    .h-meta .blk:not(.blk-name) { display: none; }
    .h-meta .blk-name h4 {
      margin-bottom: 10px;
      font-size: 13px;
    }
    .h-meta .blk-name .v { font-size: 15px; line-height: 1.65; }
  }
  @media (prefers-reduced-motion: reduce) {
    .h-head-fill { display: none; }
    .h-roles .r-line { display: none; }
    :global(.h-roles .letter) {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }
</style>