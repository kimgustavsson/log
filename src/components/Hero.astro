---
// Hero section: the "Mission"-style scattered layout with a label, a caption,
// and a justified body paragraph. The cinematic entrance animation and the
// hero-only photo trail are wired up in src/scripts (imported by BaseLayout).
//
// Props let you reuse this hero with different copy without touching markup.
interface Props {
  label?: string;
  caption?: string;
  email?: string;
  body?: string;
}

const {
  label = 'Approach',
  caption = 'MSc in Artificial Intelligence\nBased in Brisbane, Australia',
  email = 'you@example.com',
  body = "Informatics in Sweden taught me to build for people; a Master's in AI is teaching me to build with data. This space sits between the two — notes on designing intelligent systems that still feel human.",
} = Astro.props;

// Split the body into lines for the staggered line-mask reveal.
const bodyLines = body.match(/.{1,46}(\s|$)/g) ?? [body];
---

<header class="hero" id="top">
  <div class="hero-grid">
    <div class="h-label" id="hlabel" aria-label={label}>{label}</div>
    <div class="h-cap fade-up" data-delay="700">
      <div set:html={caption.replace(/\n/g, '<br>')} />
      {email && (
        <a class="h-email" href={`mailto:${email}`}>
          {email}
        </a>
      )}
    </div>
    <div class="h-body" id="hbody">
      {bodyLines.map((line) => (
        <span class="bline"><span>{line.trim()}</span></span>
      ))}
    </div>
  </div>

  <div class="hero-foot">
    <span class="scroll-cue"><span class="bar"></span>Scroll</span>
  </div>
</header>
